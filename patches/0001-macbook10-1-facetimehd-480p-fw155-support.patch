+/*
+ * Macbook10,1 specific ACPI path for the camera sensor power control.
+ * The CMPE method is defined in the DSDT at _SB_.PCI0.RP10.CMRA.CMPE.
+ * The PCI device's ACPI handle is NOT the same as the CMRA device handle.
+ */
+#define FTHD_ACPI_CAMERA_PATH "\\_SB_.PCI0.RP10.CMRA"
+
 static int isp_acpi_set_power(struct fthd_private *dev_priv, int power)
 {
 	acpi_status status;
 	acpi_handle handle;
 	struct acpi_object_list arg_list;
-	struct acpi_buffer buffer = {ACPI_ALLOCATE_BUFFER, NULL};
 	union acpi_object args[1];
-	union acpi_object *result;
-	int ret = 0;
 
-
-	handle = ACPI_HANDLE(&dev_priv->pdev->dev);
-	if(!handle) {
-		dev_err(&dev_priv->pdev->dev,
-			"Failed to get S2 CMPE ACPI handle\n");
-		ret = -ENODEV;
-		goto out;
+	/* Get the CMRA device handle directly from ACPI namespace */
+	status = acpi_get_handle(NULL, FTHD_ACPI_CAMERA_PATH, &handle);
+	if (ACPI_FAILURE(status)) {
+		dev_warn(&dev_priv->pdev->dev,
+			"Cannot resolve camera ACPI handle %s (status 0x%08x), "
+			"attempting PCIe power management only\n",
+			FTHD_ACPI_CAMERA_PATH, (unsigned)status);
+		goto pcie_only;
 	}
 
 	args[0].type = ACPI_TYPE_INTEGER;
@@ -106,29 +111,59 @@ static int isp_acpi_set_power(struct fthd_private *dev_priv, int power)
 	arg_list.count = 1;
 	arg_list.pointer = args;
 
-	status = acpi_evaluate_object(handle, "CMPE", &arg_list, &buffer);
-	if (ACPI_FAILURE(status)) {
-		dev_err(&dev_priv->pdev->dev,
-			"Failed to execute S2 CMPE ACPI method\n");
-		ret = -ENODEV;
-		goto out;
+	status = acpi_evaluate_object(handle, "CMPE", &arg_list, NULL);
+	if (ACPI_SUCCESS(status)) {
+		dev_dbg(&dev_priv->pdev->dev, "CMPE ACPI method succeeded (power=%d)\n", power);
+		return 0;
 	}
 
-	result = buffer.pointer;
-
-	if (result->type != ACPI_TYPE_INTEGER || result->integer.value != 0) {
-		dev_err(&dev_priv->pdev->dev,
-			"Invalid ACPI response (len: %Ld)\n", buffer.length);
-		ret = -EINVAL;
+	/* ACPI method call failed — this can happen on some kernels/hardware.
+	 * The CMPE method writes to PCIe config space to control power.
+	 * Fall back to standard PCIe power management. */
+	dev_warn(&dev_priv->pdev->dev,
+		"CMPE ACPI method failed (status 0x%08x), "
+		"falling back to PCIe power management\n",
+		(unsigned)status);
+
+pcie_only:
+	/* Standard PCIe power management as fallback */
+	if (power) {
+		pci_set_power_state(dev_priv->pdev, PCI_D0);
+	} else {
+		pci_set_power_state(dev_priv->pdev, PCI_D3hot);
 	}
-
-out:
-	kfree(buffer.pointer);
-	return ret;
+	return 0;
 }
 
+/*
+ * Enable the camera sensor on Macbook10,1.
+ *
+ * The ISP firmware controls the sensor via I2C after the ISP itself
+ * is powered on. This function:
+ * 1. Powers on the ISP via ACPI CMPE or PCIe fallback
+ * 2. Sets the PCI device to D0
+ * 3. Waits for the PCIe link to stabilize (DSDT waits for LACT == 1)
+ * 4. Lets the ISP firmware handle the rest (sensor I2C init)
+ */
 static int isp_enable_sensor(struct fthd_private *dev_priv)
 {
+	int ret;
+
+	/* Power on the ISP/sensor path via the Apple ACPI CMPE method.
+	 * On this MacBook10,1, skipping CMPE prevents even the old 1.43
+	 * firmware from raising its first wake interrupt.
+	 */
+	ret = isp_acpi_set_power(dev_priv, 1);
+	if (ret) {
+		dev_warn(&dev_priv->pdev->dev,
+			"isp_acpi_set_power failed, continuing anyway\n");
+	}
+
+	pci_set_power_state(dev_priv->pdev, PCI_D0);
+	mdelay(150);
+
+	dev_info(&dev_priv->pdev->dev, "Sensor power: ACPI CMPE + PCI D0\n");
+
 	return 0;
 }
 
