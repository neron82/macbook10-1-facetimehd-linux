+		 filename, dev_priv->sensor_id0, dev_priv->sensor_id1,
+		 board ? board : "unknown");
+
 	/* The set file is allowed to be missing but we don't get calibration */
 	ret = request_firmware(&fw, filename, &dev_priv->pdev->dev);
-	if (ret)
